.detail-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: calc(env(safe-area-inset-top) + 28rpx) 32rpx calc(env(safe-area-inset-bottom) + 44rpx);
  background:
    radial-gradient(circle at 78% 88%, rgba(255, 214, 241, 0.08), transparent 38%),
    radial-gradient(circle at 22% 14%, rgba(108, 99, 255, 0.15), transparent 48%),
    linear-gradient(180deg, #02030a 0%, #070b19 48%, #101a38 100%);
  color: #f4f7ff;
}

.stars-noise {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background-image:
    radial-gradient(circle at 12% 24%, rgba(244, 247, 255, 0.5) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 84% 16%, rgba(157, 187, 255, 0.45) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 64% 64%, rgba(255, 232, 163, 0.35) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 26% 78%, rgba(255, 214, 241, 0.34) 0 1rpx, transparent 2rpx);
  background-size: 230rpx 260rpx;
  opacity: 0.58;
}

.stars-noise::after {
  position: absolute;
  left: -180rpx;
  right: -180rpx;
  top: 180rpx;
  height: 520rpx;
  transform: rotate(-22deg);
  background:
    radial-gradient(ellipse at 50% 50%, rgba(244, 247, 255, 0.12), rgba(157, 187, 255, 0.07) 34%, rgba(184, 167, 255, 0.035) 52%, transparent 72%),
    radial-gradient(ellipse at 48% 52%, rgba(255, 214, 241, 0.08), transparent 62%);
  content: '';
}

.page-nav {
  position: relative;
  z-index: 2;
  height: 68rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  color: rgba(244, 247, 255, 0.88);
  font-size: 46rpx;
  line-height: 56rpx;
  text-align: center;
}

.detail-card {
  position: relative;
  z-index: 2;
  margin-top: 96rpx;
  overflow: hidden;
  padding: 58rpx 40rpx 42rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 88% 0%, rgba(255, 232, 163, 0.1), transparent 34%),
    linear-gradient(145deg, rgba(18, 28, 62, 0.54), rgba(6, 10, 27, 0.43));
  border-color: rgba(202, 221, 255, 0.18);
}

.star-glow {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  box-shadow: 0 0 32rpx currentColor, 0 0 110rpx currentColor;
}

.detail-kicker {
  margin-top: 38rpx;
  color: rgba(214, 226, 255, 0.62);
  font-size: 25rpx;
  line-height: 1.45;
}

.detail-no {
  margin-top: 20rpx;
  color: #ffe8a3;
  font-size: 27rpx;
  line-height: 1.35;
  text-shadow: 0 0 22rpx rgba(255, 232, 163, 0.28);
}

.detail-content {
  margin-top: 36rpx;
  color: rgba(252, 254, 255, 0.96);
  font-size: 36rpx;
  line-height: 1.74;
}

.detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx 32rpx;
  margin-top: 42rpx;
  color: rgba(202, 216, 255, 0.6);
  font-size: 24rpx;
  line-height: 1.4;
}

.return-btn {
  height: 78rpx;
  margin-top: 54rpx;
  border-radius: 999rpx;
  color: #fcfeff;
  font-size: 28rpx;
  line-height: 78rpx;
  text-align: center;
  background:
    radial-gradient(circle at 50% -30%, rgba(255, 255, 255, 0.54), transparent 34%),
    linear-gradient(135deg, rgba(255, 232, 163, 0.58), rgba(157, 187, 255, 0.56), rgba(108, 99, 255, 0.46));
  box-shadow:
    0 0 28rpx rgba(255, 232, 163, 0.2),
    0 0 54rpx rgba(157, 187, 255, 0.24);
}
