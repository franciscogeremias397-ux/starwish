.stars-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: calc(env(safe-area-inset-top) + 28rpx) 28rpx calc(env(safe-area-inset-bottom) + 44rpx);
  background:
    radial-gradient(circle at 78% 90%, rgba(255, 214, 241, 0.08), transparent 38%),
    radial-gradient(circle at 22% 12%, rgba(108, 99, 255, 0.14), transparent 48%),
    linear-gradient(180deg, #02030a 0%, #070b19 48%, #101a38 100%);
  color: #f4f7ff;
}

.sky-layer,
.mist {
  position: fixed;
  pointer-events: none;
}

.sky-layer {
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  overflow: hidden;
}

.sky-layer::before {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background-image:
    radial-gradient(circle at 18% 22%, rgba(244, 247, 255, 0.5) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 76% 18%, rgba(157, 187, 255, 0.45) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 42% 36%, rgba(244, 247, 255, 0.38) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 66% 72%, rgba(255, 232, 163, 0.38) 0 1rpx, transparent 2rpx);
  background-size: 220rpx 260rpx;
  opacity: 0.62;
  content: '';
}

.sky-layer::after {
  position: absolute;
  left: -260rpx;
  right: -260rpx;
  top: 180rpx;
  height: 520rpx;
  transform: rotate(-23deg);
  background:
    radial-gradient(ellipse at 50% 50%, rgba(244, 247, 255, 0.12), rgba(157, 187, 255, 0.07) 34%, rgba(184, 167, 255, 0.035) 52%, transparent 72%),
    radial-gradient(ellipse at 48% 52%, rgba(255, 214, 241, 0.08), transparent 62%);
  content: '';
}

.mist-a {
  left: -120rpx;
  top: 120rpx;
  width: 860rpx;
  height: 360rpx;
  transform: rotate(-18deg);
  background: radial-gradient(ellipse, rgba(108, 99, 255, 0.15), rgba(157, 187, 255, 0.055) 42%, transparent 70%);
}

.mist-b {
  right: -220rpx;
  bottom: 120rpx;
  width: 620rpx;
  height: 320rpx;
  background: radial-gradient(ellipse, rgba(255, 214, 241, 0.1), transparent 70%);
}

.page-nav {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  height: 68rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  color: rgba(244, 247, 255, 0.88);
  font-size: 46rpx;
  line-height: 56rpx;
  text-align: center;
}

.nav-title {
  margin-left: 20rpx;
  color: rgba(250, 253, 255, 0.96);
  font-size: 34rpx;
  font-weight: 500;
}

.summary {
  position: relative;
  z-index: 2;
  margin-top: 56rpx;
}

.summary-title {
  max-width: 620rpx;
  color: rgba(250, 253, 255, 0.96);
  font-size: 40rpx;
  font-weight: 500;
  line-height: 1.28;
}

.summary-subtitle {
  max-width: 620rpx;
  margin-top: 18rpx;
  color: rgba(214, 226, 255, 0.64);
  font-size: 25rpx;
  line-height: 1.55;
}

.star-list {
  position: relative;
  z-index: 2;
  margin-top: 46rpx;
}

.star-row {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 168rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
  padding: 28rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.08), transparent 34%),
    linear-gradient(145deg, rgba(18, 28, 62, 0.48), rgba(6, 10, 27, 0.38));
  border-color: rgba(202, 221, 255, 0.17);
}

.row-glow {
  width: 22rpx;
  height: 22rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  box-shadow: 0 0 22rpx currentColor, 0 0 60rpx currentColor;
}

.row-main {
  flex: 1;
  min-width: 0;
}

.row-date,
.row-no {
  display: block;
  color: rgba(202, 216, 255, 0.54);
  font-size: 22rpx;
  line-height: 1.3;
}

.row-content {
  display: block;
  overflow: hidden;
  margin: 12rpx 0;
  color: rgba(252, 254, 255, 0.94);
  font-size: 29rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.delete-btn {
  min-width: 86rpx;
  height: 54rpx;
  border-radius: 999rpx;
  color: rgba(255, 214, 241, 0.86);
  font-size: 23rpx;
  line-height: 54rpx;
  text-align: center;
  background: rgba(255, 214, 241, 0.08);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.empty-state {
  position: relative;
  z-index: 2;
  margin-top: 88rpx;
  padding: 58rpx 34rpx;
  border-radius: 32rpx;
  text-align: center;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 232, 163, 0.09), transparent 36%),
    linear-gradient(145deg, rgba(18, 28, 62, 0.48), rgba(6, 10, 27, 0.4));
}

.empty-star {
  width: 26rpx;
  height: 26rpx;
  margin: 0 auto 32rpx;
  border-radius: 50%;
  background: #ffe8a3;
  box-shadow: 0 0 24rpx rgba(255, 232, 163, 0.7), 0 0 82rpx rgba(255, 232, 163, 0.32);
}

.empty-title {
  color: rgba(244, 247, 255, 0.9);
  font-size: 29rpx;
  line-height: 1.5;
}

.write-btn {
  width: 220rpx;
  height: 72rpx;
  margin: 34rpx auto 0;
  border-radius: 999rpx;
  color: #fcfeff;
  font-size: 27rpx;
  line-height: 72rpx;
  background:
    radial-gradient(circle at 50% -30%, rgba(255, 255, 255, 0.6), transparent 34%),
    linear-gradient(135deg, rgba(255, 232, 163, 0.62), rgba(157, 187, 255, 0.58), rgba(108, 99, 255, 0.48));
  box-shadow:
    0 0 30rpx rgba(255, 232, 163, 0.22),
    0 0 58rpx rgba(157, 187, 255, 0.22);
}
